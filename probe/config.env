# Netprobe 2.0 – example configuration file
# Copy this file to config.env and adjust values as needed.

# -------------------------------
# Web UI
# -------------------------------
WEB_PORT=8080
# Allow enough time for a full official Ookla test to finish through Gunicorn.
GUNICORN_TIMEOUT=240

# -------------------------------
# Storage backend
# -------------------------------
# SQLite file path (used when DB_ENGINE=sqlite)
DB_PATH=/data/netprobe.sqlite

# Database backend selector:
#   sqlite   -> use DB_PATH file
#   postgres -> use external Postgres (see POSTGRES_* below)
DB_ENGINE=postgres

# Alternatively, you can leave DB_ENGINE unset and use:
#USE_POSTGRES=true
# to force Postgres mode. If both are set, DB_ENGINE wins.

# -------------------------------
# Postgres configuration
# -------------------------------
# These are used when DB_ENGINE=postgres or USE_POSTGRES=true.
# They should match the postgres service in docker-compose.yml.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=netprobe
POSTGRES_USER=netprobe
POSTGRES_PASSWORD=netprobe

# -------------------------------
# Probe timing
# -------------------------------
PROBE_INTERVAL=30
PING_COUNT=4

# -------------------------------
# Ping targets
# -------------------------------
# Comma-separated list of hosts to ping
SITES=fast.com,google.com,youtube.com
# Optional router IP on your LAN; leave blank to skip
#ROUTER_IP=192.168.1.1

# -------------------------------
# DNS configuration
# -------------------------------
# Legacy single-domain variable still works:
# DNS_TEST_SITE=google.com
#
# New preferred variable for multiple DNS lookup targets.
# Netprobe will average these lookup results per DNS server.
DNS_TEST_SITES=google.com,youtube.com,amazon.com

DNS_NAMESERVER_1=Google_DNS
DNS_NAMESERVER_1_IP=8.8.8.8

DNS_NAMESERVER_2=Quad9_DNS
DNS_NAMESERVER_2_IP=9.9.9.9

DNS_NAMESERVER_3=CloudFlare_DNS
DNS_NAMESERVER_3_IP=1.1.1.1

#DNS_NAMESERVER_4=My_DNS_Server
#DNS_NAMESERVER_4_IP=192.168.1.1

# -------------------------------
# Internet Quality Score Weights
# -------------------------------
WEIGHT_LOSS=0.6
WEIGHT_LATENCY=0.15
WEIGHT_JITTER=0.2
WEIGHT_DNS_LATENCY=0.05

# -------------------------------
# Internet Quality Score Thresholds
# -------------------------------
THRESHOLD_LOSS=5
THRESHOLD_LATENCY=100
THRESHOLD_JITTER=30
THRESHOLD_DNS_LATENCY=100

# -------------------------------
# Speedtest configuration
# -------------------------------
SPEEDTEST_ENABLED=True
# 4 hours = 14400 seconds
SPEEDTEST_INTERVAL=14400

# Speedtest backend:
#   python -> existing Python speedtest-cli implementation (default)
#   ookla  -> official /usr/bin/speedtest CLI
SPEEDTEST_BACKEND=python

# The official Ookla CLI is separate proprietary software for personal,
# non-commercial use. End-user acknowledgement must happen at runtime and is
# never saved in the Docker image. After reviewing Ookla's EULA, Terms of Use,
# and Privacy Policy, use ONE of these methods:
#   docker exec -it <container> netprobe-ookla-accept
# or acknowledge non-interactively, then install:
#   SPEEDTEST_OOKLA_ACCEPT_LICENSE=I_ACCEPT
#   docker exec <container> netprobe-ookla-accept --install
SPEEDTEST_OOKLA_ACCEPT_LICENSE=
SPEEDTEST_OOKLA_ACCEPTANCE_FILE=/data/ookla-eula-accepted.txt
SPEEDTEST_OOKLA_PATH=/usr/bin/speedtest
SPEEDTEST_OOKLA_TIMEOUT=180

# Use HTTPS for Speedtest server discovery and tests with the Python backend.
# The official Ookla backend uses its native protocol and ignores this value.
# HTTP and HTTPS may
# return different server ID lists. The web UI can override this setting for
# an individual manual run.
SPEEDTEST_SECURE=True

# Optional: force speedtest to use a specific server ID.
# Leave blank to use automatic best server selection.
# The web UI can override this value for a one-off manual run.
SPEEDTEST_SERVER=

# Optional multi-server selection mode.
# False + SPEEDTEST_SERVER set  -> use the single server above.
# False + SPEEDTEST_SERVER blank -> automatic best-server selection.
# True                          -> use SPEEDTEST_CSV_SERVERS instead.
SPEEDTEST_CSV=False

# CSV server pool used when SPEEDTEST_CSV=True.
# Counted format requested for Docker/Unraid:
#   2,12345,23456
# Plain CSV is also accepted:
#   12345,23456
#SPEEDTEST_CSV_SERVERS=

# Global comma-separated server exclusion list. These IDs are excluded from
# automatic, single-server, CSV-pool, and one-off manual tests.
# Example: 46408,4392
#SPEEDTEST_EXCLUDE=

# Live log viewer polling interval in seconds.
# This only affects how often the web UI refreshes its log tail panel.
LIVE_LOG_POLL_SECONDS=2

# -------------------------------
# Timezone label (for UI only)
# -------------------------------
APP_TIMEZONE=UTC
